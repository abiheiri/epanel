{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build epanel",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/bin/ninja",
            "args": ["-C", "${workspaceFolder}/build"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}
