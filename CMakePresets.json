{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "macos-local-qt",
      "inherits": "base",
      "displayName": "macOS (local aqtinstall Qt)",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "/Users/al/Documents/epanel_cpp/.qt/6.12.0/macos/6.12.0/macos"
      }
    },
    {
      "name": "macos-homebrew",
      "inherits": "base",
      "displayName": "macOS (Homebrew Qt)",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "/opt/homebrew/opt/qt@6"
      }
    },
    {
      "name": "linux",
      "inherits": "base",
      "displayName": "Linux (system Qt6)",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "windows",
      "inherits": "base",
      "displayName": "Windows (adjust Qt path)",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "C:/Qt/6.12.0/msvc2019_64"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "macos-local-qt",
      "configurePreset": "macos-local-qt"
    },
    {
      "name": "macos-homebrew",
      "configurePreset": "macos-homebrew"
    },
    {
      "name": "linux",
      "configurePreset": "linux"
    },
    {
      "name": "windows",
      "configurePreset": "windows"
    }
  ]
}
